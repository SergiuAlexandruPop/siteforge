# ============================================
# SiteForge — Environment Variables Template
# ============================================
# Copy this file to env/.env.{client-name}
# Example: cp env/.env.example env/.env.doctor-maria
# ============================================

# ============================================
# CLIENT IDENTITY
# ============================================
# Must match the folder name in clients/
ACTIVE_CLIENT=

# ============================================
# CLOUDFLARE R2 (Image Storage)
# ============================================
# Dashboard: https://dash.cloudflare.com → R2 Object Storage
# Free tier: 10GB storage, 10M reads/month, free egress
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ============================================
# RESEND (Contact Form Emails)
# ============================================
# Dashboard: https://resend.com
# Free tier: 100 emails/day, 3000/month, 1 custom domain
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TO_EMAIL=

# ============================================
# GITHUB API (CMS — Blog File Operations)
# ============================================
# Token: https://github.com/settings/tokens
# Required scope: repo (read/write file contents)
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main

# ============================================
# ADMIN CMS
# ============================================
# Password for /admin login — use a strong password (12+ chars)
ADMIN_PASSWORD=
# Random string for cookie signing — generate with: openssl rand -hex 16
ADMIN_SESSION_SECRET=

# ============================================
# SMARTSUPP (Optional — leave empty to disable)
# ============================================
# Dashboard: https://www.smartsupp.com
NEXT_PUBLIC_SMARTSUPP_ID=

# ============================================
# GOOGLE ANALYTICS (Optional — leave empty to disable)
# ============================================
# Dashboard: https://analytics.google.com
NEXT_PUBLIC_GA4_ID=

# ============================================
# SUPABASE (Optional — leave empty if not used)
# ============================================
# Dashboard: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
