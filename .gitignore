# Dependencies
node_modules/
.pnp
.pnp.js

# Next.js
.next/
out/

# Build
dist/
build/

# Raw field photos (source for scripts/optimize-photos.ts). Only the optimized
# WebP under clients/*/public/lucrari/ is committed; the originals never are
# (large, and carry EXIF/GPS until stripped).
photos-raw/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
env/.env.*
!env/.env.example

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Generated per-client entry (regenerated before every dev/build, on postinstall)
src/lib/active-client.generated.ts

# Route-gating stash (scripts/gate-routes.ts moves blog/CMS routes here during a
# non-blog build, then restores them — should never be committed or left behind)
.gated-routes/

# Playwright E2E
test-results/
playwright-report/
playwright/.cache/

# Cloudflare / OpenNext
.open-next/
.wrangler/

# Vercel
.vercel
