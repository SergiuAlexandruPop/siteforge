{
  "name": "siteforge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "pretypecheck": "tsx scripts/gen-active-client.ts",
    "postinstall": "tsx scripts/gen-active-client.ts",
    "gen:client": "tsx scripts/gen-active-client.ts",
    "new-client": "tsx scripts/new-client.ts",
    "toggle-feature": "tsx scripts/toggle-feature.ts",
    "dev:portfolio": "tsx scripts/dev.ts portfolio",
    "build:portfolio": "cross-env ACTIVE_CLIENT=portfolio tsx scripts/gen-active-client.ts && cross-env ACTIVE_CLIENT=portfolio next build",
    "dev:electrowill-solutions": "tsx scripts/dev.ts electrowill-solutions",
    "build:electrowill-solutions": "cross-env ACTIVE_CLIENT=electrowill-solutions tsx scripts/gen-active-client.ts && cross-env ACTIVE_CLIENT=electrowill-solutions next build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "jose": "^5.9.0",
    "lenis": "^1.3.20",
    "motion": "^12.38.0",
    "next": "^15.1.0",
    "novel": "^0.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "resend": "^4.1.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  }
}
